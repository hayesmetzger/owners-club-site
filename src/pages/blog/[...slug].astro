---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';

export async function getStaticPaths() {
  const now = new Date();
  const posts = await getCollection('blog');
  return posts
    .filter((post) => !post.data.draft && post.data.pubDate <= now)
    .map((post) => ({
      params: { slug: post.id },
      props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const { title, description, pubDate, updatedDate, heroImage, series, episode, author, tags } = post.data;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
const ogImagePath = heroImage?.src;
const absoluteImage = ogImagePath ? new URL(ogImagePath, Astro.site).toString() : undefined;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  datePublished: pubDate.toISOString(),
  ...(updatedDate && { dateModified: updatedDate.toISOString() }),
  author: {
    '@type': 'Organization',
    name: author,
    url: Astro.site?.toString(),
  },
  publisher: {
    '@type': 'Organization',
    name: 'Owners Club',
    url: Astro.site?.toString(),
    sameAs: ['https://www.youtube.com/@TheOwnersAcademy'],
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': canonicalUrl,
  },
  ...(absoluteImage && { image: absoluteImage }),
  ...(tags.length > 0 && { keywords: tags.join(', ') }),
};
---

<BaseLayout
  title={`${title} — Owners Club`}
  description={description}
  ogType="article"
  ogImage={ogImagePath}
  publishedTime={pubDate}
  author={author}
  keywords={tags}
  jsonLd={jsonLd}
>
  <article class="blog-post">
    <div class="container post-container">
      <header class="post-header">
        {series && (
          <p class="series-label">
            {series}{episode != null && ` · Episode ${episode}`}
          </p>
        )}
        <time datetime={pubDate.toISOString()}>
          {pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        <h1>{title}</h1>
        <p class="post-description">{description}</p>
      </header>
      {heroImage && (
        <figure class="post-hero">
          <Image src={heroImage} alt={title} widths={[480, 800, 1200]} sizes="(max-width: 720px) 100vw, 720px" />
        </figure>
      )}
      <div class="post-content">
        <Content />
      </div>
      <footer class="post-footer">
        <a href="/blog">&larr; Back to blog</a>
      </footer>
    </div>
  </article>
</BaseLayout>

<style>
  .blog-post {
    padding: 3rem 0;
  }

  .post-container {
    max-width: 720px;
  }

  .post-header {
    margin-bottom: 2rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--oc-cream);
  }

  .series-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--oc-gold);
    font-weight: 600;
    margin-bottom: 0.75rem;
  }

  .post-hero {
    margin: 0 0 2.5rem;
  }

  .post-hero img {
    width: 100%;
    height: auto;
    border-radius: 12px;
    display: block;
  }

  .post-header time {
    font-size: 0.85rem;
    color: var(--oc-mid-gray);
    display: block;
    margin-bottom: 1rem;
  }

  .post-header h1 {
    font-size: 2.5rem;
    line-height: 1.15;
    margin-bottom: 1rem;
  }

  .post-description {
    font-size: 1.15rem;
    color: var(--oc-slate);
    line-height: 1.6;
  }

  .post-content :global(h2) {
    font-family: var(--font-headline);
    font-size: 1.5rem;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    color: var(--oc-black);
  }

  .post-content :global(p) {
    font-size: 1.05rem;
    line-height: 1.75;
    margin-bottom: 1.25rem;
    color: var(--oc-slate);
  }

  .post-content :global(strong) {
    color: var(--oc-black);
  }

  .post-footer {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--oc-cream);
  }

  .post-footer a {
    color: var(--oc-gold);
    font-weight: 600;
    font-size: 0.95rem;
  }

  @media (max-width: 640px) {
    .post-header h1 {
      font-size: 1.75rem;
    }
  }
</style>
