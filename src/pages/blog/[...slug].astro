---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={`${post.data.title} — Owners Club`} description={post.data.description}>
  <article class="blog-post">
    <div class="container post-container">
      <header class="post-header">
        <time datetime={post.data.pubDate.toISOString()}>
          {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        <h1>{post.data.title}</h1>
        <p class="post-description">{post.data.description}</p>
      </header>
      <div class="post-content">
        <Content />
      </div>
      <footer class="post-footer">
        <a href="/blog">&larr; Back to blog</a>
      </footer>
    </div>
  </article>
</BaseLayout>

<style>
  .blog-post {
    padding: 3rem 0;
  }

  .post-container {
    max-width: 720px;
  }

  .post-header {
    margin-bottom: 3rem;
    border-bottom: 1px solid var(--oc-cream);
    padding-bottom: 2rem;
  }

  .post-header time {
    font-size: 0.85rem;
    color: var(--oc-mid-gray);
    display: block;
    margin-bottom: 1rem;
  }

  .post-header h1 {
    font-size: 2.5rem;
    line-height: 1.15;
    margin-bottom: 1rem;
  }

  .post-description {
    font-size: 1.15rem;
    color: var(--oc-slate);
    line-height: 1.6;
  }

  .post-content :global(h2) {
    font-family: var(--font-headline);
    font-size: 1.5rem;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    color: var(--oc-black);
  }

  .post-content :global(p) {
    font-size: 1.05rem;
    line-height: 1.75;
    margin-bottom: 1.25rem;
    color: var(--oc-slate);
  }

  .post-content :global(strong) {
    color: var(--oc-black);
  }

  .post-footer {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--oc-cream);
  }

  .post-footer a {
    color: var(--oc-gold);
    font-weight: 600;
    font-size: 0.95rem;
  }

  @media (max-width: 640px) {
    .post-header h1 {
      font-size: 1.75rem;
    }
  }
</style>
