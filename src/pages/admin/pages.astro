---
import { getSql, ensureEventsTable } from '../../lib/db';
import { checkBasicAuth, unauthorizedResponse } from '../../lib/admin-auth';

export const prerender = false;

if (!checkBasicAuth(Astro.request)) {
  return unauthorizedResponse();
}

type PageRow = {
  path: string;
  views: number;
  sessions: number;
  last_viewed: string;
};

let pageRows: PageRow[] = [];
let totalViews = 0;
let totalSessions = 0;
let viewsLast24h = 0;
let loadError: string | null = null;

const sql = getSql();

if (!sql) {
  loadError = 'DATABASE_URL not configured.';
} else {
  try {
    await ensureEventsTable(sql);

    pageRows = (await sql`
      SELECT properties->>'path' AS path,
             COUNT(*)::int AS views,
             COUNT(DISTINCT session_id)::int AS sessions,
             MAX(created_at) AS last_viewed
      FROM events
      WHERE name = 'page_view'
        AND properties->>'path' IS NOT NULL
      GROUP BY properties->>'path'
      ORDER BY views DESC
    `) as PageRow[];

    const totals = (await sql`
      SELECT
        COUNT(*)::int AS total,
        COUNT(DISTINCT session_id)::int AS sessions,
        COUNT(*) FILTER (WHERE created_at > NOW() - INTERVAL '24 hours')::int AS last24
      FROM events
      WHERE name = 'page_view'
    `) as Array<{ total: number; sessions: number; last24: number }>;
    totalViews = totals[0]?.total ?? 0;
    totalSessions = totals[0]?.sessions ?? 0;
    viewsLast24h = totals[0]?.last24 ?? 0;
  } catch (err) {
    console.error('admin pages query failed', err);
    loadError = 'Failed to load page views.';
  }
}

function fmt(value: string | null) {
  if (!value) return '—';
  return new Date(value).toLocaleString('en-US', {
    dateStyle: 'short',
    timeStyle: 'short',
  });
}
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex,nofollow" />
    <title>Pages — Admin</title>
    <style>
      * { box-sizing: border-box; }
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
        margin: 0;
        background: #0b1220;
        color: #e5e7eb;
        padding: 2rem;
      }
      h1 {
        font-size: 1.5rem;
        margin: 0 0 0.5rem;
      }
      nav {
        margin-bottom: 1.5rem;
        font-size: 0.875rem;
      }
      nav a {
        color: #9ca3af;
        text-decoration: none;
        margin-right: 1rem;
      }
      nav a:hover { color: #d4af37; }
      nav a.active { color: #fff; font-weight: 600; }
      .stats {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
        margin-bottom: 1.5rem;
      }
      .stat {
        background: #111827;
        border: 1px solid #1f2937;
        border-radius: 8px;
        padding: 0.875rem 1.25rem;
        min-width: 140px;
      }
      .stat-label {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #9ca3af;
        margin-bottom: 0.25rem;
      }
      .stat-value {
        font-size: 1.5rem;
        font-weight: 600;
        color: #fff;
      }
      table {
        width: 100%;
        border-collapse: collapse;
        background: #111827;
        border: 1px solid #1f2937;
        border-radius: 8px;
        overflow: hidden;
        font-size: 0.875rem;
      }
      th, td {
        padding: 0.625rem 0.875rem;
        text-align: left;
        border-bottom: 1px solid #1f2937;
      }
      th {
        background: #0f172a;
        font-weight: 600;
        color: #9ca3af;
        text-transform: uppercase;
        font-size: 0.7rem;
        letter-spacing: 0.05em;
      }
      td.num, th.num { text-align: right; font-variant-numeric: tabular-nums; }
      tr:last-child td { border-bottom: 0; }
      tr:hover td { background: #0f172a; }
      td.path {
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
        color: #d1d5db;
      }
      .empty {
        text-align: center;
        padding: 3rem;
        color: #6b7280;
      }
      .error {
        background: #7f1d1d;
        color: #fecaca;
        padding: 1rem;
        border-radius: 6px;
      }
    </style>
  </head>
  <body>
    <h1>Page views</h1>
    <nav>
      <a href="/admin/signups">Signups</a>
      <a href="/admin/pages" class="active">Pages</a>
      <a href="/admin/analytics">Analytics</a>
    </nav>

    {loadError && <div class="error">{loadError}</div>}

    {!loadError && (
      <>
        <div class="stats">
          <div class="stat">
            <div class="stat-label">Total views</div>
            <div class="stat-value">{totalViews.toLocaleString()}</div>
          </div>
          <div class="stat">
            <div class="stat-label">Unique sessions</div>
            <div class="stat-value">{totalSessions.toLocaleString()}</div>
          </div>
          <div class="stat">
            <div class="stat-label">Views (24h)</div>
            <div class="stat-value">{viewsLast24h.toLocaleString()}</div>
          </div>
          <div class="stat">
            <div class="stat-label">Pages tracked</div>
            <div class="stat-value">{pageRows.length}</div>
          </div>
        </div>

        {pageRows.length === 0 ? (
          <div class="empty">No page views yet.</div>
        ) : (
          <table>
            <thead>
              <tr>
                <th>Path</th>
                <th class="num">Views</th>
                <th class="num">Unique sessions</th>
                <th>Last viewed</th>
              </tr>
            </thead>
            <tbody>
              {pageRows.map((r) => (
                <tr>
                  <td class="path">{r.path}</td>
                  <td class="num">{r.views.toLocaleString()}</td>
                  <td class="num">{r.sessions.toLocaleString()}</td>
                  <td>{fmt(r.last_viewed)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        )}
      </>
    )}
  </body>
</html>
